<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Perkins American Food Co. | Modern Redesign</title>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;600;700&family=Nunito:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary-yellow: #FFD100;
            --primary-green: #007A53;
            --accent-orange: #FF6B35;
            --dark-text: #2D2A26;
            --light-bg: #FFFDF7;
            --white: #FFFFFF;
            --shadow: 0 10px 30px rgba(0,0,0,0.08);
            --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Nunito', sans-serif;
            background-color: var(--light-bg);
            color: var(--dark-text);
            overflow-x: hidden;
        }

        h1, h2, h3, .brand {
            font-family: 'Fredoka', sans-serif;
        }

        /* Navbar */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 5%;
            background-color: var(--white);
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .brand {
            font-size: 28px;
            font-weight: 700;
            color: var(--primary-green);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-links {
            display: flex;
            gap: 30px;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--dark-text);
            font-weight: 600;
            font-size: 18px;
            transition: var(--transition);
        }

        .nav-links a:hover {
            color: var(--accent-orange);
        }

        .btn {
            padding: 12px 28px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 800;
            font-size: 18px;
            border: none;
            cursor: pointer;
            transition: var(--transition);
            display: inline-block;
        }

        .btn-primary {
            background-color: var(--accent-orange);
            color: var(--white);
            box-shadow: 0 5px 15px rgba(255, 107, 53, 0.3);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(255, 107, 53, 0.4);
            background-color: #FA5A22;
        }

        .btn-secondary {
            background-color: var(--primary-yellow);
            color: var(--dark-text);
        }

        .btn-secondary:hover {
            transform: translateY(-3px);
            background-color: #F0C400;
        }

        /* Hero Section */
        .hero {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 60px 5%;
            background: linear-gradient(135deg, #FFFDF7 0%, #FFF5CC 100%);
            min-height: 80vh;
        }

        .hero-content {
            flex: 1;
            padding-right: 50px;
            animation: slideUp 0.8s ease forwards;
        }

        .badge {
            display: inline-block;
            background-color: var(--primary-green);
            color: var(--white);
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 800;
            font-size: 14px;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .hero h1 {
            font-size: 4rem;
            line-height: 1.1;
            margin-bottom: 20px;
            color: var(--dark-text);
        }

        .hero h1 span {
            color: var(--accent-orange);
        }

        .hero p {
            font-size: 1.2rem;
            margin-bottom: 30px;
            color: #555;
            line-height: 1.6;
        }

        .hero-buttons {
            display: flex;
            gap: 15px;
        }

        .hero-image {
            flex: 1;
            position: relative;
            animation: fadeIn 1.2s ease forwards;
        }

        .hero-image img {
            width: 100%;
            border-radius: 40px;
            box-shadow: var(--shadow);
            transform: rotate(-2deg);
            transition: var(--transition);
        }

        .hero-image img:hover {
            transform: rotate(0deg) scale(1.02);
        }

        .floating-element {
            position: absolute;
            background: var(--white);
            padding: 15px 25px;
            border-radius: 30px;
            box-shadow: var(--shadow);
            font-weight: 800;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: float 4s ease-in-out infinite;
        }

        .float-1 { top: -20px; left: -30px; color: var(--accent-orange); }
        .float-2 { bottom: -20px; right: -20px; color: var(--primary-green); animation-delay: 2s; }

        /* Features Section (Current Promos) */
        .promos {
            padding: 80px 5%;
            text-align: center;
        }

        .promos h2 {
            font-size: 3rem;
            margin-bottom: 50px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
        }

        .card {
            background: var(--white);
            border-radius: 30px;
            padding: 30px;
            box-shadow: var(--shadow);
            transition: var(--transition);
            position: relative;
            overflow: hidden;
            text-align: left;
        }

        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.12);
        }

        .card-emoji {
            font-size: 3rem;
            margin-bottom: 20px;
        }

        .card h3 {
            font-size: 1.8rem;
            margin-bottom: 15px;
            color: var(--primary-green);
        }

        .card p {
            font-size: 1.1rem;
            color: #666;
            margin-bottom: 20px;
        }

        .card a {
            text-decoration: none;
            color: var(--accent-orange);
            font-weight: 800;
            font-size: 1.1rem;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        /* Build-A-Breakfast Section */
        .interactive-section {
            background-color: var(--primary-green);
            color: var(--white);
            padding: 80px 5%;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-radius: 50px;
            margin: 0 2% 80px 2%;
        }

        .interactive-text {
            flex: 1;
            padding-right: 40px;
        }

        .interactive-text h2 {
            font-size: 3.5rem;
            margin-bottom: 20px;
            color: var(--primary-yellow);
        }

        .steps {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-top: 30px;
        }

        .step-box {
            background: rgba(255,255,255,0.1);
            padding: 20px;
            border-radius: 20px;
            flex: 1;
            min-width: 150px;
            backdrop-filter: blur(10px);
        }

        .step-num {
            font-family: 'Fredoka', sans-serif;
            font-size: 2rem;
            color: var(--primary-yellow);
            margin-bottom: 10px;
        }

        /* Footer */
        footer {
            background-color: var(--dark-text);
            color: var(--white);
            padding: 60px 5%;
            text-align: center;
            border-top-left-radius: 50px;
            border-top-right-radius: 50px;
        }

        /* Animations */
        @keyframes float {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
            100% { transform: translateY(0px); }
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Responsive */
        @media (max-width: 900px) {
            .hero, .interactive-section {
                flex-direction: column;
                text-align: center;
            }
            .hero-content, .interactive-text {
                padding-right: 0;
                margin-bottom: 40px;
            }
            .hero-buttons {
                justify-content: center;
            }
            .nav-links {
                display: none; /* Hide on mobile for simplicity in this demo */
            }
        }
    </style>
</head>
<body>

    <header>
        <a href="#" class="brand">
            🥞 Perkins
        </a>
        <ul class="nav-links">
            <li><a href="#">Menu</a></li>
            <li><a href="#">Locations</a></li>
            <li><a href="#">About Us</a></li>
            <li><a href="#">Gift Cards</a></li>
        </ul>
        <a href="#" class="btn btn-primary">Order Now</a>
    </header>

    <section class="hero">
        <div class="hero-content">
            <div class="badge">Back by popular demand!</div>
            <h1>Give your stomach and wallet <span>a hug.</span></h1>
            <p>The famous $10.99 Burger, Fries, and Pie combo is back! Dive into your favorite classic comfort foods with a modern twist. Hot or cold, it's always cozy here.</p>
            <div class="hero-buttons">
                <a href="#" class="btn btn-primary">Order Delivery</a>
                <a href="#" class="btn btn-secondary">Find a Location</a>
            </div>
        </div>
        <div class="hero-image">
            <div class="floating-element float-1">🍔 Juicy Burger</div>
            <div class="floating-element float-2">🥧 Free Slice of Pie</div>
            <img src="https://images.unsplash.com/photo-1550547660-d9450f859349?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80" alt="Delicious Burger and Fries">
        </div>
    </section>

    <section class="promos">
        <h2>What's Cooking? 🔥</h2>
        <div class="grid">
            <div class="card">
                <div class="card-emoji">🥞</div>
                <h3>Pie Pancakes</h3>
                <p>A pie that woke up early! Try our NEW French Silk, Wildberry, and Caramel Apple Pie Pancake Platters.</p>
                <a href="#">Taste the Magic <span>→</span></a>
            </div>
            <div class="card">
                <div class="card-emoji">☕</div>
                <h3>French Silk Brews</h3>
                <p>Hot Chocolate or Cold Brew inspired by our most indulgent, creamy French Silk pie. Perfect for any weather.</p>
                <a href="#">Sip Sip Hooray <span>→</span></a>
            </div>
            <div class="card">
                <div class="card-emoji">🥘</div>
                <h3>Family Meals</h3>
                <p>Comfort meals without the cooking. Bring home one of six delicious new Family Meals that serve 4.</p>
                <a href="#">Feed the Crew <span>→</span></a>
            </div>
        </div>
    </section>

    <section class="interactive-section">
        <div class="interactive-text">
            <h2>Build-A-Breakfast 🍳</h2>
            <p>You know what you like for breakfast, and we like that. Made to order, your way, every single time. Combine your favorites!</p>
            <div class="steps">
                <div class="step-box">
                    <div class="step-num">01.</div>
                    <strong>The Classics</strong><br>2 farm-raised eggs & your choice of bacon or sausage.
                </div>
                <div class="step-box">
                    <div class="step-num">02.</div>
                    <strong>The Crunch</strong><br>Crispy hash browns, tots, or fresh fruit.
                </div>
                <div class="step-box">
                    <div class="step-num">03.</div>
                    <strong>The Topper</strong><br>Pancakes, a Mammoth Muffin®, or fresh biscuits.
                </div>
            </div>
            <br><br>
            <a href="#" class="btn btn-secondary">Start Building Now</a>
        </div>
    </section>

    <footer>
        <h2>🥞 Perkins American Food Co.</h2>
        <p style="margin: 20px 0; color: #aaa;">Things Change. Traditions Last. Since 1958.</p>
        <p style="color: #666; font-size: 14px;">© 2026 Perkins LLC. All rights reserved. Redesigned for fun!</p>
    </footer>

    <script>
        // Add a smooth reveal effect on scroll for the promo cards
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if(entry.isIntersecting) {
                    entry.target.style.opacity = 1;
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.card').forEach(card => {
            card.style.opacity = 0;
            card.style.transform = 'translateY(30px)';
            card.style.transition = 'all 0.6s ease-out';
            observer.observe(card);
        });
    </script>
</body>
</html>
